# =============================================================
# Shopping Market — Admin Dashboard env
# Copy to .env.local. Vite exposes only VITE_* to client code.
# =============================================================

# Backend HTTP base URL — must end with /api/v1
VITE_API_BASE_URL=http://34.124.228.3:8000/api/v1

# Optional explicit WebSocket base; if omitted Layout.jsx derives it from
# VITE_API_BASE_URL by swapping http→ws and stripping /api/v1.
VITE_WS_BASE_URL=

# Google Maps — required for live tracking + branch map picker
VITE_GOOGLE_MAPS_API_KEY=

# Sentry (optional)
VITE_SENTRY_DSN=
