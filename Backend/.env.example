# ─── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,api.shopping-market.com
# Set True in any environment served over HTTPS (behind a TLS-terminating
# proxy). Enables SECURE_PROXY_SSL_HEADER so Django trusts X-Forwarded-Proto
# and build_absolute_uri() emits https:// media/image URLs (required by iOS ATS).
HTTPS_ENABLED=True

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_NAME=shopping_market
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ─── Cache & queues ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list. Add the admin dashboard + Flutter dev origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,https://admin.shopping-market.com

# ─── S3 / Object storage ──────────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=shopping-market-prod
AWS_S3_REGION_NAME=me-south-1

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────────
# Path to the service-account JSON file shipped with the deployment image.
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ─── SMS / OTP provider ───────────────────────────────────────────────────────
# 'log' = print to logs in DEBUG mode only (default for dev).
# Other options: vonage, twilio. Wire the real client in apps/users/otp_views.py
SMS_PROVIDER=log
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=ShoppingMkt

# ─── Payment gateways ─────────────────────────────────────────────────────────
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
FAWRY_MERCHANT_CODE=

# ─── Loyalty defaults (overridable via /admin/settings) ───────────────────────
POINTS_PER_EGP=1
POINTS_VALUE_EGP=0.05
POINTS_RATING_BONUS=5

# ─── Order timing ─────────────────────────────────────────────────────────────
WEIGHT_DIFF_APPROVAL_TIMEOUT_MINS=15
AUTO_CLOSE_TIMEOUT_HOURS=2
