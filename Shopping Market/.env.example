# =============================================================
# Shopping Market — Flutter customer app environment
# Copy to `.env` and fill in.
#
# Loaded at runtime via flutter_dotenv (and `--dart-define` for
# release builds). Defaults live in lib/core/constants/api_constants.dart.
# =============================================================

# Backend HTTP base URL — must end with /api/v1
API_BASE_URL=http://63.33.70.240:8000/api/v1

# WebSocket base URL (no trailing slash, no /api prefix)
WS_BASE_URL=ws://63.33.70.240:8000

# Google services
GOOGLE_MAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=

# Facebook OAuth (flutter_facebook_auth)
FACEBOOK_APP_ID=
FACEBOOK_CLIENT_TOKEN=

# Sentry — optional crash + perf reporting
SENTRY_DSN=

# Build flavors — set the API target per environment
# dev / staging / prod
APP_FLAVOR=dev
